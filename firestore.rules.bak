rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      // Un usuario solo puede leer/escribir su propio perfil
      allow read, write: if isOwner(userId);
      // Permitir a otros leer perfiles (para ver conductor/pasajeros)
      allow get: if isSignedIn();

      // Un usuario puede leer su propio historial de viajes
      match /rideHistory/{historyId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /wallets/{userId} {
      allow read, create: if isOwner(userId);
      allow update: if false; // Solo desde backend
    }

    // --- REGLAS PARA VIAJES (CORREGIDAS) ---
    match /rides/{rideId} {
      
      // Cualquiera que haya iniciado sesión puede ver la lista de viajes y los detalles
      allow read: if isSignedIn();
      
      // Un usuario solo puede crear un viaje para sí mismo
      allow create: if isSignedIn() && request.resource.data.driverId == request.auth.uid;
      
      // Solo el conductor puede actualizar o borrar su viaje
      allow update, delete: if isSignedIn() && resource.data.driverId == request.auth.uid;
    }

    match /rideRequests/{requestId} {
        allow read, create: if isSignedIn();
        allow update, delete: if isOwner(resource.data.requesterId);
    }

    match /packages/{packageId} { 
        allow read, create: if isSignedIn(); 
        allow update, delete: if isOwner(resource.data.senderId);
    }

    match /chats/{chatId} {
      // Cualquiera de los participantes puede leer o escribir en el chat
      allow read, write: if isSignedIn() && request.auth.uid in resource.data.participantUids;
    }
  }
}
