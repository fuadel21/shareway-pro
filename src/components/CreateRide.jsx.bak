import React, { useState, useCallback, useEffect, useRef } from 'react';
import { useOutletContext, useNavigate } from 'react-router-dom';
import { toast } from 'sonner';
import { Button } from '@/components/ui/button.jsx';
import { Input } from '@/components/ui/input.jsx';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card.jsx';
import { Popover, PopoverContent, PopoverTrigger } from '@/components/ui/popover';
import { Calendar } from '@/components/ui/calendar';
import { Loader2, CalendarIcon, CheckCircle, Info } from 'lucide-react';
import { format } from 'date-fns';
import { es } from 'date-fns/locale';
import GooglePlacesAutocomplete from './GooglePlacesAutocomplete.jsx';
import { createSingleRide } from '../services/rideService.js';
import { cn } from '@/lib/utils';

const COST_PER_KM = 0.12;

const getNextHalfHour = () => {
    const now = new Date();
    now.setMinutes(Math.ceil(now.getMinutes() / 30) * 30, 0, 0);
    if (now <= new Date()) now.setMinutes(now.getMinutes() + 30);
    return `${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}`;
};

const CreateRide = () => {
    const { mapsLoaded, profile: currentUserProfile } = useOutletContext();
    const navigate = useNavigate();
    
    const [origin, setOrigin] = useState(null);
    const [destination, setDestination] = useState(null);
    const [date, setDate] = useState(new Date());
    const [time, setTime] = useState(getNextHalfHour);
    const [seats, setSeats] = useState('2');
    const [price, setPrice] = useState('');
    const [isSubmitting, setIsSubmitting] = useState(false);
    
    // Usamos una ref para guardar los datos de la ruta para evitar problemas de estado
    const routeDataRef = useRef(null);

    const handleOriginSelect = useCallback((place) => place && setOrigin({ address: place.address, coordinates: place.coordinates }), []);
    const handleDestinationSelect = useCallback((place) => place && setDestination({ address: place.address, coordinates: place.coordinates }), []);

    useEffect(() => {
        if (origin && destination && window.google) {
            const directionsService = new window.google.maps.DirectionsService();
            directionsService.route({
                origin: origin.coordinates,
                destination: destination.coordinates,
                travelMode: window.google.maps.TravelMode.DRIVING,
            }, (result, status) => {
                if (status === 'OK' && result.routes[0]) {
                    const route = result.routes[0];
                    const distanceInKm = route.legs.reduce((sum, leg) => sum + leg.distance.value, 0) / 1000;
                    const suggestedPrice = (distanceInKm * COST_PER_KM).toFixed(2);
                    
                    setPrice(suggestedPrice.replace('.', ','));

                    // Guardamos los datos de la ruta en la ref
                    routeDataRef.current = {
                        distance: distanceInKm,
                        overview_polyline: route.overview_polyline,
                        bounds: { ne: route.bounds.getNorthEast().toJSON(), sw: route.bounds.getSouthWest().toJSON() }
                    };
                    console.log('Ruta calculada y guardada:', routeDataRef.current);
                } else {
                    routeDataRef.current = null;
                    setPrice('');
                    console.warn('Error al calcular la ruta:', status);
                }
            });
        }
    }, [origin, destination]);

    const handleCreateRide = async (e) => {
        e.preventDefault();
        if (!currentUserProfile) return toast.error("Debes iniciar sesión para publicar.");
        if (!origin || !destination || !routeDataRef.current) return toast.error("Selecciona un origen y destino válidos.");
        if (!date || !time) return toast.error("Especifica una fecha y hora de salida.");
        
        const numericSeats = Number(seats);
        if (isNaN(numericSeats) || numericSeats <= 0) return toast.error("El número de asientos no es válido.");
        
        const priceWithDot = price.replace(',', '.');
        const numericPrice = Number(priceWithDot);
        if (isNaN(numericPrice) || numericPrice < 0) return toast.error("El precio por asiento no es válido.");

        setIsSubmitting(true);
        try {
            const [hours, minutes] = time.split(':').map(Number);
            const rideDateTime = new Date(date);
            rideDateTime.setHours(hours, minutes, 0, 0);

            const rideData = {
                origin, 
                destination, 
                dateTime: rideDateTime, 
                seats: numericSeats, 
                price: numericPrice,
                ...routeDataRef.current // <-- Añadimos los datos de la ruta al objeto
            };
            
            console.log('Enviando estos datos para crear el viaje:', rideData);
            await createSingleRide(rideData, currentUserProfile);
            
            toast.success('¡Viaje publicado con éxito!');
            navigate('/my-rides');

        } catch (error) {
            console.error("Error al publicar el viaje:", error);
            toast.error('Error al publicar el viaje', { description: error.message });
        } finally {
            setIsSubmitting(false);
        }
    };
    
    if (!mapsLoaded || !currentUserProfile) return <div className="h-screen flex items-center justify-center"><Loader2 className="animate-spin"/> Cargando...</div>;

    return (
        <div className="max-w-2xl mx-auto p-4">
            <Card>
                <CardHeader>
                    <CardTitle>Publicar un nuevo viaje</CardTitle>
                    <CardDescription>Completa los detalles de tu ruta para que otros puedan unirse.</CardDescription>
                </CardHeader>
                <CardContent>
                    <form onSubmit={handleCreateRide} className="space-y-6">
                        <div className="space-y-2">
                            <div><label className="block text-sm font-medium mb-1">Origen</label><GooglePlacesAutocomplete key="origin-autocomplete" id="origin" placeholder="Lugar de salida" onPlaceSelect={handleOriginSelect} /></div>
                            <div><label className="block text-sm font-medium mb-1">Destino</label><GooglePlacesAutocomplete key="destination-autocomplete" id="destination" placeholder="Lugar de llegada" onPlaceSelect={handleDestinationSelect} /></div>
                        </div>
                        
                        <div className="grid grid-cols-2 gap-4">
                            <div>
                                <label className="block text-sm font-medium mb-1">Fecha de salida</label>
                                <Popover>
                                    <PopoverTrigger asChild>
                                        <Button variant={"outline"} className={cn("w-full justify-start text-left font-normal", !date && "text-muted-foreground")}>
                                            <CalendarIcon className="mr-2 h-4 w-4" />
                                            {date ? format(date, "PPP", { locale: es }) : <span>Elige una fecha</span>}
                                        </Button>
                                    </PopoverTrigger>
                                    <PopoverContent className="w-auto p-0"><Calendar mode="single" selected={date} onSelect={setDate} initialFocus fromDate={new Date()} /></PopoverContent>
                                </Popover>
                            </div>
                            <div>
                                <label className="block text-sm font-medium mb-1">Hora</label>
                                <Input id="time" type="time" value={time} onChange={(e) => setTime(e.target.value)} required />
                            </div>
                        </div>

                        <div className="grid grid-cols-2 gap-4">
                           <div><label className="block text-sm font-medium mb-1">Asientos disponibles</label><Input id="seats" type="number" value={seats} onChange={(e) => setSeats(e.target.value)} min="1" max="8" required /></div>
                           <div>
                                <label className="block text-sm font-medium mb-1">Precio por asiento (€)</label>
                                <Input id="price" type="text" inputMode="decimal" value={price} onChange={(e) => setPrice(e.target.value)} required placeholder="ej: 15,50"/>
                           </div>
                        </div>
                        <Button type="submit" disabled={isSubmitting || !origin || !destination} className="w-full h-12 text-base">
                            {isSubmitting ? <Loader2 className="mr-2 h-4 w-4 animate-spin" /> : <CheckCircle className="mr-2 h-5 w-5"/>}
                            Publicar Viaje
                        </Button>
                    </form>
                </CardContent>
            </Card>
        </div>
    );
};

export default CreateRide;
