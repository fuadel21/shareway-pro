import React, { useState, useEffect, useMemo, useCallback, useRef } from 'react';
import { GoogleMap, MarkerF } from '@react-google-maps/api';
import { useOutletContext, Link, useNavigate } from 'react-router-dom';
import { db } from '../lib/firebase';
import { collection, query, where, onSnapshot } from 'firebase/firestore';
import { format } from 'date-fns';
import { es } from 'date-fns/locale';
import { cn } from '@/lib/utils';
import { Button } from '@/components/ui/button.jsx';
import { Input } from '@/components/ui/input.jsx';
import { Plus, Search, LocateFixed, Globe, Users, Car, List } from 'lucide-react';

const mapContainerStyle = { height: '100%', width: '100%' };

const mapOptions = {
    disableDefaultUI: true,
    zoomControl: true,
    streetViewControl: false,
    mapTypeControl: false,
    fullscreenControl: false,
    zoomControlOptions: {
        position: 3 // google.maps.ControlPosition.TOP_RIGHT
    },
};

const SPAIN_CENTER = { lat: 40.416775, lng: -3.703790 };

const toLatLng = (coords) => coords ? (coords.latitude ? { lat: coords.latitude, lng: coords.longitude } : coords) : null;

const ItemCard = ({ item, navigate }) => {
    const { origin, destination, dateTime, id, status, passengerUids, seatsTotal, price } = item;
    const linkTo = `/ride/${id}`;
    const formattedTime = dateTime?.toDate ? format(dateTime.toDate(), "HH:mm", { locale: es }) : '';
    const formattedDate = dateTime?.toDate ? format(dateTime.toDate(), "dd 'de' MMMM", { locale: es }) : 'Fecha no disp.';
    const passengersCount = passengerUids?.length || 0;

    return (
        <div 
            className="bg-white border rounded-lg p-4 mb-3 shadow-sm cursor-pointer hover:shadow-md transition-shadow"
            onClick={() => navigate(linkTo)}
        >
            <div className="flex justify-between items-start mb-2">
                <p className="font-bold text-lg truncate max-w-[70%]">De {origin?.address || 'N/A'}</p>
                <span className="px-2 py-1 text-xs font-semibold rounded-full bg-blue-100 text-blue-800">Programado</span>
            </div>
            <p className="text-md text-muted-foreground -mt-1 mb-3 truncate max-w-[80%]">A {destination?.address || 'N/A'}</p>
            <div className="flex justify-between items-center text-sm">
                <p className="text-muted-foreground">{formattedDate} a las <span className="font-semibold text-foreground">{formattedTime}</span></p>
                <div className="flex items-center gap-4">
                    <div className="flex items-center gap-1.5 text-muted-foreground">
                        <Users className="h-4 w-4" />
                        <span className="font-semibold text-foreground">{passengersCount} / {seatsTotal || '-'}</span>
                    </div>
                    <p className="font-bold text-lg text-primary">{price?.toFixed(2) || '0.00'}€</p>
                </div>
            </div>
        </div>
    );
};

function LiveDashboardMap() {
    const { user, mapsLoaded } = useOutletContext();
    const navigate = useNavigate();
    
    const [publicRides, setPublicRides] = useState([]);
    const [publicRequests, setPublicRequests] = useState([]);
    const [searchTerm, setSearchTerm] = useState("");
    const [activeFilter, setActiveFilter] = useState('Próximos');
    const [isPanelExpanded, setIsPanelExpanded] = useState(true);
    const [userLocation, setUserLocation] = useState(null);
    const mapRef = useRef(null);

    useEffect(() => { 
        if (!user) return;
        navigator.geolocation.getCurrentPosition( (position) => { setUserLocation({ lat: position.coords.latitude, lng: position.coords.longitude }); }, () => console.warn("No se pudo obtener la ubicación del usuario."), { timeout: 10000 } ); 
    }, [user]);
    
    useEffect(() => {
        if (!user) return;
        const ridesQuery = query(collection(db, 'rides'), where('status', 'in', ['scheduled', 'active']));
        const unsubRides = onSnapshot(ridesQuery, (snap) => setPublicRides(snap.docs.map(d => ({ ...d.data(), id: d.id, type: 'ride' })))); 
        const requestsQuery = query(collection(db, 'rideRequests'), where('status', '==', 'pending'));
        const unsubRequests = onSnapshot(requestsQuery, (snap) => setPublicRequests(snap.docs.map(d => ({ ...d.data(), id: d.id, type: 'request' })))); 
        return () => { unsubRides(); unsubRequests(); }; 
    }, [user]);

    const itemsToDisplay = useMemo(() => {
        if (!user) return [];

        let items;
        switch (activeFilter) {
            case 'Próximos':
                items = publicRides.filter(r => r.status === 'scheduled');
                break;
            case 'En curso':
                items = publicRides.filter(r => r.status === 'active');
                break;
            case 'Solicitudes':
                items = publicRequests;
                break;
            default:
                items = [...publicRides, ...publicRequests];
                break;
        }

        const userFilteredItems = items.filter(item => item.driverId !== user.uid);

        const searchFiltered = searchTerm
            ? userFilteredItems.filter(i => 
                (i.origin?.address || '').toLowerCase().includes(searchTerm.toLowerCase()) || 
                (i.destination?.address || '').toLowerCase().includes(searchTerm.toLowerCase())
              )
            : userFilteredItems;

        return searchFiltered.sort((a, b) => (a.dateTime?.toDate() || 0) - (b.dateTime?.toDate() || 0));
    }, [publicRides, publicRequests, searchTerm, activeFilter, user]);

    const onMapLoad = useCallback((map) => (mapRef.current = map), []);
    const handleLocateMe = () => { if (userLocation && mapRef.current) { mapRef.current.panTo(userLocation); mapRef.current.setZoom(14); } };
    const handleGlobalView = () => { if (mapRef.current) { mapRef.current.panTo(SPAIN_CENTER); mapRef.current.setZoom(6); } };

    if (!mapsLoaded) {
        return <div className="flex items-center justify-center h-full">Cargando mapa...</div>;
    }

    const FilterButton = ({ label, icon: Icon }) => ( <Button variant={activeFilter === label ? 'secondary' : 'ghost'} className="flex-1 justify-start text-base font-normal" onClick={() => setActiveFilter(label)}>{Icon && <Icon className="mr-3 h-4 w-4 text-muted-foreground"/>}{label}</Button> );

    return (
        <div className="w-full h-full relative overflow-hidden">
            <GoogleMap
                mapContainerStyle={mapContainerStyle}
                center={SPAIN_CENTER}
                zoom={6}
                options={mapOptions}
                onLoad={onMapLoad}
                onClick={() => setIsPanelExpanded(isExpanded => !isExpanded)}
                onDragStart={() => setIsPanelExpanded(false)}
            >
                {itemsToDisplay.map((item) => (<MarkerF key={`marker-${item.id}`} position={toLatLng(item.origin.coordinates)} onClick={() => navigate(`/ride/${item.id}`)} />))}
            </GoogleMap>

            <div className="absolute top-[100px] right-4 flex flex-col gap-2 z-10">
                <Button size="icon" onClick={handleLocateMe} title="Mi ubicación"><LocateFixed className="h-5 w-5" /></Button>
                <Button size="icon" onClick={handleGlobalView} title="Vista global"><Globe className="h-5 w-5" /></Button>
            </div>

            <div 
                className={cn(
                    "absolute bottom-0 left-0 right-0 z-20 pt-4 bg-background rounded-t-2xl shadow-[0_-4px_16px_rgba(0,0,0,0.1)]",
                    "transition-transform duration-300 ease-in-out",
                    isPanelExpanded ? "translate-y-0" : "translate-y-[calc(100%-100px)]"
                )}
            >
                 <div className="w-full px-4" onClick={() => setIsPanelExpanded(!isPanelExpanded)} > <div className="w-12 h-1.5 bg-muted rounded-full mx-auto cursor-pointer"></div> </div>
                 <div className="px-4 pt-4 space-y-4"> 
                    <div className="grid grid-cols-2 gap-3"> 
                        <Button size="lg" asChild><Link to="/create-ride"><Plus className="mr-2 h-5 w-5"/>Publica tu viaje</Link></Button> 
                        <Button size="lg" variant="outline" asChild><Link to="/create-request"><Search className="mr-2 h-5 w-5"/>Solicita un viaje</Link></Button> 
                    </div> 
                    <div> 
                        <div className="grid grid-cols-2 gap-x-4 gap-y-1"> <FilterButton label="Próximos" icon={Car} /> <FilterButton label="En curso" icon={Car} /> <FilterButton label="Solicitudes" icon={Users} /> <FilterButton label="Todos" icon={List} /> </div> 
                        <div className="relative mt-4"> <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-5 w-5 text-muted-foreground" /> <Input type="search" placeholder="Buscar en la lista..." className="pl-10 h-12 text-base" value={searchTerm} onChange={e => setSearchTerm(e.target.value)} /> </div> 
                    </div> 
                    <div className="h-[calc(50vh-220px)] min-h-[150px] overflow-y-auto pr-1"> 
                        {itemsToDisplay.length > 0 ? itemsToDisplay.map(item => <ItemCard key={item.id} item={item} navigate={navigate} />) : <div className="flex flex-col items-center justify-center h-full text-center text-muted-foreground"><Car className="w-12 h-12 mb-4"/><p>No hay viajes que coincidan.</p></div>} 
                    </div> 
                </div>
            </div>
        </div>
    );
}

export default LiveDashboardMap;
