import { db } from '../lib/firebase';
import { collection, doc, addDoc, getDocs, query, where, serverTimestamp, GeoPoint } from 'firebase/firestore';
import { AppError, handleFirebaseError } from '../lib/errors';

export const getPublishedRides = async () => {
    try {
        const ridesRef = collection(db, 'rides');
        const q = query(ridesRef, where('status', '==', 'scheduled'));
        const querySnapshot = await getDocs(q);
        const rides = querySnapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
        return rides;
    } catch (error) {
        throw handleFirebaseError(error, "al obtener los viajes publicados");
    }
};

export const createSingleRide = async (rideData, driverProfile) => {
    try {
        if (!driverProfile?.uid) throw new AppError('profile/incomplete', "Tu perfil está incompleto.");
        if (!rideData.origin.coordinates || !rideData.destination.coordinates) throw new AppError('validation/no-coords', "Las coordenadas no son válidas.");

        const newRide = {
            // --- Datos del Conductor (Formato Correcto) ---
            driverId: driverProfile.uid, 
            driverInfo: {
                name: driverProfile.displayName || 'Sin nombre',
                photoURL: driverProfile.photoURL || null
            },

            // --- Datos del Viaje ---
            status: 'scheduled',
            createdAt: serverTimestamp(),
            dateTime: rideData.dateTime,
            price: rideData.price,
            seatsAvailable: rideData.seats,
            seatsTotal: rideData.seats,
            
            // --- Geometría y Ruta ---
            origin: { 
                address: rideData.origin.address, 
                coordinates: new GeoPoint(rideData.origin.coordinates.lat, rideData.origin.coordinates.lng) 
            },
            destination: { 
                address: rideData.destination.address, 
                coordinates: new GeoPoint(rideData.destination.coordinates.lat, rideData.destination.coordinates.lng) 
            },
            distance: rideData.distance,
            overview_polyline: rideData.overview_polyline,
            bounds: rideData.bounds,

            // --- Datos de Pasajeros ---
            participantIds: [driverProfile.uid], // <-- ¡¡LA SOLUCIÓN!!
            passengerUids: [],
            pendingPassengerUids: [],
        };

        const rideDocRef = await addDoc(collection(db, 'rides'), newRide);
        return rideDocRef.id;

    } catch (error) {
        throw handleFirebaseError(error, "al publicar el viaje");
    }
};

