rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn();
      match /rideHistory/{historyId} { allow read, write: if isSignedIn(); }
    }

    match /favoriteRoutes/{routeId} {
        allow read, write: if isSignedIn();
    }

    match /wallets/{userId} {
      allow read, create: if isOwner(userId);
      allow update: if false; // Prevent accidental updates
      match /transactions/{transactionId} { allow read: if isOwner(userId); }
    }

    match /rides/{rideId} {
      allow read, write: if isSignedIn();
    }

    match /rideRequests/{requestId} {
        allow read, write: if isSignedIn();
    }

    match /packages/{packageId} { 
        allow read, write: if isSignedIn();
    }

    match /chats/{chatId} {
      allow read, write: if isSignedIn();
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /communities/{communityId} {
      allow read, write: if isSignedIn();
    }

    match /calls/{callId} {
      allow read, write: if isSignedIn();
      match /candidates/{candidateId} {
        allow read, write: if isSignedIn();
      }
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource == null);
      allow write: if isSignedIn();
    }
  }
}
